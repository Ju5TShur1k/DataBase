-- =====================================================
-- SQL-ЗАПРОСЫ К БАЗЕ ДАННЫХ "ЗООПАРК"
-- =====================================================

-- =====================================================
-- 1. ЗАПРОС ИЗ ОДНОЙ ТАБЛИЦЫ
-- Задача: Найти всех ветеринаров с зарплатой больше 60000, вывести их ФИО и зарплату
-- =====================================================

SELECT '1. Ветеринары с зарплатой > 60000' AS Запрос;
SELECT ФИО, Зарплата 
FROM Сотрудник 
WHERE Категория = 'Ветеринар' AND Зарплата > 60000;


-- =====================================================
-- 2.1 ЗАПРОС С ДВУМЯ ТАБЛИЦАМИ
-- Задача: Найти всех сотрудников-дрессировщиков и название зоопарков, в которых они работают
-- =====================================================

SELECT '2.1 Дрессировщики и зоопарки, в которых они работают' AS Запрос;
SELECT С.ФИО, С.Категория, З.Название AS Зоопарк
FROM Сотрудник С
JOIN Зоопарк З ON С.РК_зоопарка = З.РК
WHERE С.Категория = 'Дрессировщик';


-- =====================================================
-- 2.2 ЗАПРОС С ДВУМЯ ТАБЛИЦАМИ
-- Задача: Найти всех сотрудников, имеющих доступ к клеткам
-- =====================================================

SELECT '2.2 Сотрудники, имеющие доступ к клеткам' AS Запрос;
SELECT С.ФИО, С.Категория, П.Доступ_к_вольерам
FROM Сотрудник С
JOIN Проф_направленность П ON С.РК = П.РК_сотрудника
WHERE П.Доступ_к_вольерам IS NOT NULL;


-- =====================================================
-- 3.1 ЗАПРОС С ТРЕМЯ ТАБЛИЦАМИ
-- Задача: Найти вид корма, тип корма и объем порций для кормлений хищников в 9:00
-- =====================================================

SELECT '3.1 Кормление хищников в 9:00' AS Запрос;
SELECT К.Вид, К.Тип_корма, М.Объем_порции
FROM Животное Ж
JOIN Меню_на_день М ON Ж.РК = М.РК_животного
JOIN Корм К ON М.РК_корма = К.РК
WHERE Ж.Тип = 'Хищник' AND М.Время = '09:00:00';


-- =====================================================
-- 3.2 ЗАПРОС С ТРЕМЯ ТАБЛИЦАМИ
-- Задача: Найти всех ветеринаров, которые работают в отапливаемых вольерах, вывести ФИО ветеринара и номер вольера
-- =====================================================

SELECT '3.2 Ветеринары, работающие в отапливаемых вольерах"' AS Запрос;
SELECT С.ФИО, В.Номер_вольера
FROM Сотрудник С
JOIN Вольер_Сотрудник ВС ON С.РК = ВС.РК_сотрудника
JOIN Вольер В ON ВС.РК_вольера = В.РК
WHERE С.Категория = 'Ветеринар' AND В.Отапливаемый = TRUE;


-- =====================================================
-- 4.1 ДОБАВЛЕНИЕ ИНФОРМАЦИИ
-- Задача: Добавить нового дрессировщика «Орлов Д.Е.» с зарплатой 58000, возрастом 33 года
-- =====================================================

SELECT '4.1 Добавление нового дрессировщика' AS Запрос;
INSERT INTO Сотрудник (ФИО, Категория, Зарплата, Возраст, Дата_попадания_в_зоопарк, РК_зоопарка)
VALUES ('Орлов Дмитрий Евгеньевич', 'Дрессировщик', 58000, 33, CURRENT_DATE, 2);

-- Проверка добавления
SELECT * FROM Сотрудник 


-- =====================================================
-- 4.2 УДАЛЕНИЕ ИНФОРМАЦИИ
-- Задача: Удалить всех животных, которые уже не в зоопарке (дата ухода не NULL)
-- =====================================================

SELECT '4.2 Удаление животных, покинувших зоопарк' AS Запрос;
DELETE FROM Животное WHERE Дата_ухода_из_зоопарка IS NOT NULL;
-- Проверка удаления
SELECT * FROM Животное;


-- =====================================================
-- 4.3 КОРРЕКТИРОВКА ИНФОРМАЦИИ
-- Задача: Изменить зарплату всех дрессировщиков зоопарка «Центральный» на +5000
-- =====================================================

SELECT '4.3 Увеличение зарплаты дрессировщиков зоопарка "Центральный" на 5000' AS Запрос;
UPDATE Сотрудник 
SET Зарплата = Зарплата + 5000 
FROM Зоопарк
WHERE Сотрудник.РК_зоопарка = Зоопарк.РК
AND Зоопарк.Название = 'Центральный зоопарк'
AND Сотрудник.Категория = 'Дрессировщик';

-- Проверка корректировки
SELECT С.ФИО, С.Категория, С.Зарплата, З.Название AS Зоопарк
FROM Сотрудник С
JOIN Зоопарк З ON С.РК_зоопарка = З.РК
WHERE С.Категория = 'Дрессировщик' AND З.Название = 'Центральный зоопарк';

SELECT '5.1 Количество животных по типам' AS Запрос;
SELECT 
    Тип AS Тип_животного, 
    COUNT(РК) AS Количество
FROM Животное
GROUP BY Тип
ORDER BY Количество DESC;


SELECT '5.2 Средняя зарплата по категориям' AS Запрос;
SELECT 
    Категория, 
    ROUND(AVG(Зарплата), 2) AS Средняя_зарплата
FROM Сотрудник
GROUP BY Категория
ORDER BY Средняя_зарплата DESC;


SELECT '5.3 Объём кормов по типам' AS Запрос;
SELECT 
    Тип_корма,
    SUM(Объем_на_складе) AS Общий_объём_кг
FROM Корм
GROUP BY Тип_корма
ORDER BY Общий_объём_кг DESC;



SELECT '6. Ветеринары, лечившие "Вирусную инфекцию"' AS Запрос;
SELECT DISTINCT С.ФИО AS Ветеринар
FROM Сотрудник С
WHERE EXISTS (
    SELECT 1
    FROM Лечение_Сотрудник ЛС
    JOIN Лечение Л ON ЛС.РК_лечения = Л.РК
    WHERE ЛС.РК_сотрудника = С.РК
      AND Л.Диагноз = 'Вирусная инфекция'
      AND С.Категория = 'Ветеринар'
);


