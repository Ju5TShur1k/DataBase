-- БАЗА ДАННЫХ "ЗООПАРК"
-- Лабораторная работа №4
-- =====================================================

-- Удаление таблиц (для чистой пересборки)
DROP TABLE IF EXISTS Животное_Лечение CASCADE;
DROP TABLE IF EXISTS Лечение_Сотрудник CASCADE;
DROP TABLE IF EXISTS Вольер_Сотрудник CASCADE;
DROP TABLE IF EXISTS Корм_Поставщик_кормов CASCADE;
DROP TABLE IF EXISTS Поставщик_кормов_Зоопарк CASCADE;
DROP TABLE IF EXISTS Меню_на_день CASCADE;
DROP TABLE IF EXISTS Корм CASCADE;
DROP TABLE IF EXISTS Поставщик_кормов CASCADE;
DROP TABLE IF EXISTS Потомство CASCADE;
DROP TABLE IF EXISTS Проф_направленность CASCADE;
DROP TABLE IF EXISTS Лечение CASCADE;
DROP TABLE IF EXISTS Животное CASCADE;
DROP TABLE IF EXISTS Вольер CASCADE;
DROP TABLE IF EXISTS Сотрудник CASCADE;
DROP TABLE IF EXISTS Зоопарк CASCADE;

-- =====================================================
-- 1. Зоопарк
-- =====================================================
CREATE TABLE Зоопарк (
    РК SERIAL PRIMARY KEY,
    Название VARCHAR(100) NOT NULL UNIQUE,
    Адрес VARCHAR(200) NOT NULL
);

-- =====================================================
-- 2. Сотрудник
-- =====================================================
CREATE TABLE Сотрудник (
    РК SERIAL PRIMARY KEY,
    ФИО VARCHAR(150) NOT NULL,
    Категория VARCHAR(30) CHECK (Категория IN ('Ветеринар', 'Уборщик', 'Дрессировщик', 'Строитель-ремонтник', 'Администратор')),
    Зарплата DECIMAL(10, 2) CHECK (Зарплата >= 0),
    Возраст INTEGER CHECK (Возраст >= 16 AND Возраст <= 100),
    Дата_попадания_в_зоопарк DATE NOT NULL DEFAULT CURRENT_DATE,
    Дата_ухода_из_зоопарка DATE,
    РК_зоопарка INTEGER NOT NULL,
    FOREIGN KEY (РК_зоопарка) REFERENCES Зоопарк(РК) ON DELETE CASCADE
);

-- =====================================================
-- 3. Вольер
-- =====================================================
CREATE TABLE Вольер (
    РК SERIAL PRIMARY KEY,
    Номер_вольера VARCHAR(20) NOT NULL UNIQUE,
    Тип VARCHAR(20) CHECK (Тип IN ('Хищники', 'Травоядные', 'Смешанный')),
    Климатическая_зона VARCHAR(50) NOT NULL,
    Соседи TEXT,
    Отапливаемый BOOLEAN DEFAULT FALSE,
    РК_зоопарка INTEGER NOT NULL,
    FOREIGN KEY (РК_зоопарка) REFERENCES Зоопарк(РК) ON DELETE CASCADE
);

-- =====================================================
-- 4. Связующая таблица: Вольер_Сотрудник (многие-ко-многим)
-- =====================================================
CREATE TABLE Вольер_Сотрудник (
    РК SERIAL PRIMARY KEY,
    РК_вольера INTEGER NOT NULL,
    РК_сотрудника INTEGER NOT NULL,
    FOREIGN KEY (РК_вольера) REFERENCES Вольер(РК) ON DELETE CASCADE,
    FOREIGN KEY (РК_сотрудника) REFERENCES Сотрудник(РК) ON DELETE CASCADE
);

-- =====================================================
-- 5. Животное
-- =====================================================
CREATE TABLE Животное (
    РК SERIAL PRIMARY KEY,
    Кличка VARCHAR(100) NOT NULL,
    Вид VARCHAR(100) NOT NULL,
    Тип VARCHAR(20) CHECK (Тип IN ('Хищник', 'Травоядное')),
    Служащие TEXT,
    Дата_попадания_в_зоопарк DATE NOT NULL DEFAULT CURRENT_DATE,
    Дата_ухода_из_зоопарка DATE,
    РК_вольера INTEGER NOT NULL,
    FOREIGN KEY (РК_вольера) REFERENCES Вольер(РК) ON DELETE CASCADE
);

-- =====================================================
-- 6. Проф_направленность
-- =====================================================
CREATE TABLE Проф_направленность (
    РК SERIAL PRIMARY KEY,
    Доступ_к_вольерам TEXT,
    Задачи TEXT,
    РК_сотрудника INTEGER NOT NULL,
    FOREIGN KEY (РК_сотрудника) REFERENCES Сотрудник(РК) ON DELETE CASCADE
);

-- =====================================================
-- 7. Потомство
-- =====================================================
CREATE TABLE Потомство (
    РК SERIAL PRIMARY KEY,
    Возраст VARCHAR(50) NOT NULL,
    Количество_особей INTEGER DEFAULT 0 CHECK (Количество_особей >= 0),
    РК_вольера INTEGER NOT NULL,
    FOREIGN KEY (РК_вольера) REFERENCES Вольер(РК) ON DELETE CASCADE
);

-- =====================================================
-- 8. Поставщик_кормов
-- =====================================================
CREATE TABLE Поставщик_кормов (
    РК SERIAL PRIMARY KEY,
    Компания VARCHAR(100) NOT NULL,
    Адрес VARCHAR(200) NOT NULL,
    Специализация VARCHAR(100)
);

-- =====================================================
-- 9. Связующая таблица: Поставщик_кормов_Зоопарк (многие-ко-многим)
-- =====================================================
CREATE TABLE Поставщик_кормов_Зоопарк (
    РК SERIAL PRIMARY KEY,
    РК_поставщика INTEGER NOT NULL,
    РК_зоопарка INTEGER NOT NULL,
    FOREIGN KEY (РК_поставщика) REFERENCES Поставщик_кормов(РК) ON DELETE CASCADE,
    FOREIGN KEY (РК_зоопарка) REFERENCES Зоопарк(РК) ON DELETE CASCADE
);

-- =====================================================
-- 10. Корм
-- =====================================================
CREATE TABLE Корм (
    РК SERIAL PRIMARY KEY,
    Вид VARCHAR(100) NOT NULL,
    Тип_корма VARCHAR(30) CHECK (Тип_корма IN ('Растительный', 'Живой', 'Мясо', 'Комбикорм')),
    Объем_на_складе DECIMAL(10, 2) DEFAULT 0 CHECK (Объем_на_складе >= 0)
);

-- =====================================================
-- 11. Связующая таблица: Корм_Поставщик_кормов (многие-ко-многим)
-- =====================================================
CREATE TABLE Корм_Поставщик_кормов (
    РК SERIAL PRIMARY KEY,
    РК_корма INTEGER NOT NULL,
    РК_поставщика INTEGER NOT NULL,
    FOREIGN KEY (РК_корма) REFERENCES Корм(РК) ON DELETE CASCADE,
    FOREIGN KEY (РК_поставщика) REFERENCES Поставщик_кормов(РК) ON DELETE CASCADE
);

-- =====================================================
-- 12. Меню на день
-- =====================================================
CREATE TABLE Меню_на_день (
    РК SERIAL PRIMARY KEY,
    Дата DATE NOT NULL,
    Время TIME NOT NULL,
    Объем_порции DECIMAL(10, 2) NOT NULL CHECK (Объем_порции > 0),
    РК_животного INTEGER NOT NULL,
    РК_корма INTEGER NOT NULL,
    FOREIGN KEY (РК_животного) REFERENCES Животное(РК) ON DELETE CASCADE,
    FOREIGN KEY (РК_корма) REFERENCES Корм(РК) ON DELETE CASCADE
);

-- =====================================================
-- 13. Лечение
-- =====================================================
CREATE TABLE Лечение (
    РК SERIAL PRIMARY KEY,
    Диагноз VARCHAR(200) NOT NULL,
    Дата_начала DATE NOT NULL,
    Дата_окончания DATE,
    Назначение TEXT,
    Изолирован BOOLEAN DEFAULT FALSE
);

-- =====================================================
-- 14. Связующая таблица: Лечение_Сотрудник (многие-ко-многим)
-- =====================================================
CREATE TABLE Лечение_Сотрудник (
    РК SERIAL PRIMARY KEY,
    РК_лечения INTEGER NOT NULL,
    РК_сотрудника INTEGER NOT NULL,
    FOREIGN KEY (РК_лечения) REFERENCES Лечение(РК) ON DELETE CASCADE,
    FOREIGN KEY (РК_сотрудника) REFERENCES Сотрудник(РК) ON DELETE CASCADE
);

-- =====================================================
-- 15. Связующая таблица: Животное_Лечение (многие-ко-многим)
-- =====================================================
CREATE TABLE Животное_Лечение (
    РК SERIAL PRIMARY KEY,
    РК_животного INTEGER NOT NULL,
    РК_лечения INTEGER NOT NULL,
    FOREIGN KEY (РК_животного) REFERENCES Животное(РК) ON DELETE CASCADE,
    FOREIGN KEY (РК_лечения) REFERENCES Лечение(РК) ON DELETE CASCADE
);

